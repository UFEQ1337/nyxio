# Token bota Discord (Developer Portal -> Bot -> Token)
NYXIO_DISCORD_TOKEN=your-bot-token-here

# Opcjonalnie: ID gildii do natychmiastowej synchronizacji slash-komend (dev)
NYXIO_DEV_GUILD_ID=


# Limity ochronne
NYXIO_MAX_QUEUE_SIZE=500
NYXIO_MAX_PLAYLIST_ITEMS=100
NYXIO_IDLE_TIMEOUT_SECONDS=180

# Redis (opcjonalny write-through snapshot kolejek). Pusty = wyłączony.
NYXIO_REDIS_URL=redis://redis:6379/0

# Lavalink (serwer audio). Host/port wskazują serwis z docker-compose.
NYXIO_LAVALINK_HOST=lavalink
NYXIO_LAVALINK_PORT=2333
NYXIO_LAVALINK_PASSWORD=youshallnotpass

# OAuth YouTube (omija "This video requires login" na VPS). Zostaw puste
# przy 1. starcie — Lavalink wypisze w logach link+kod do autoryzacji
# (zaloguj BURNER konto Google). Potem wklej tu wypisany refreshToken.
NYXIO_YOUTUBE_REFRESH_TOKEN=
# WAZNE: PO_TOKEN i VISITOR_DATA musza pochodzic z JEDNEGO przebiegu
# generatora (np. iv-org/youtube-trusted-session-generator) — niesparowana
# lub stara para = blad "Video player configuration error" w Lavalink.
NYXIO_PO_TOKEN=tutaj_wklej_krotszy_kod_potoken
NYXIO_VISITOR_DATA=tutaj_wklej_dluzszy_kod_visitor_data_czesniej_zaczyna_sie_od_Cgt

# Haslo wspoldzielone miedzy serwisem yt-cipher (zdalny deszyfrator
# sygnatur YouTube) a Lavalinkiem. Dowolny sekret; musi byc niepuste.
# Naprawia blad "must find sig function" przy nowym player-script YT.
NYXIO_YTCIPHER_TOKEN=zmien-na-dowolny-sekret
# Token bota Discord (Developer Portal -> Bot -> Token)
NYXIO_DISCORD_TOKEN=your-bot-token-here

# Opcjonalnie: ID gildii do natychmiastowej synchronizacji slash-komend (dev)
NYXIO_DEV_GUILD_ID=


# Limity ochronne
NYXIO_MAX_QUEUE_SIZE=500
NYXIO_MAX_PLAYLIST_ITEMS=100
NYXIO_IDLE_TIMEOUT_SECONDS=180

# Redis (opcjonalny write-through snapshot kolejek). Pusty = wyłączony.
NYXIO_REDIS_URL=redis://redis:6379/0

# Lavalink (serwer audio). Host/port wskazują serwis z docker-compose.
NYXIO_LAVALINK_HOST=lavalink
NYXIO_LAVALINK_PORT=2333
NYXIO_LAVALINK_PASSWORD=youshallnotpass

# ─── Bot (czytane przez nyxio.config.Settings, prefiks NYXIO_) ────────────

# Token bota Discord (Developer Portal -> Bot -> Token)
NYXIO_DISCORD_TOKEN=your-bot-token-here

# Opcjonalnie: ID gildii do natychmiastowej synchronizacji slash-komend (dev).
# Puste = synchronizacja globalna (do ~1h propagacji).
NYXIO_DEV_GUILD_ID=

# Limity ochronne
NYXIO_MAX_QUEUE_SIZE=500
NYXIO_MAX_PLAYLIST_ITEMS=100
NYXIO_IDLE_TIMEOUT_SECONDS=180

# Redis (opcjonalny write-through snapshot kolejek dla /wznow).
# Pusty = wyłączony (wtedy /wznow zawsze zwraca "brak sesji").
NYXIO_REDIS_URL=redis://redis:6379/0

# Lavalink (serwer audio). Host/port wskazują serwis z docker-compose.
NYXIO_LAVALINK_HOST=lavalink
NYXIO_LAVALINK_PORT=2333
NYXIO_LAVALINK_PASSWORD=youshallnotpass

# ─── Lavalink/YouTube (czytane przez docker-compose.yml) ─────────────────

# OAuth YouTube (omija "This video requires login" na VPS). Zostaw puste
# przy 1. starcie — Lavalink wypisze w logach link+kod do autoryzacji
# (zaloguj BURNER konto Google). Potem wklej tu wypisany refreshToken.
NYXIO_YOUTUBE_REFRESH_TOKEN=

# Sekret współdzielony Lavalink <-> yt-cipher (zdalny deszyfrator sygnatur
# YouTube). Dowolny niepusty sekret; ten sam po obu stronach (compose
# podstawia go i jako API_TOKEN yt-cipher, i jako hasło remoteCipher).
# Naprawia błąd "must find sig function" przy nowym player-script YT.
NYXIO_YTCIPHER_TOKEN=zmien-na-dowolny-sekret

# poToken/visitorData — puste = wyłączone (zwykle wystarcza yt-cipher +
# OAuth). Jeśli wypełniasz: oba MUSZĄ pochodzić z JEDNEGO przebiegu
# generatora (np. iv-org/youtube-trusted-session-generator) — niesparowana
# lub stara para = błąd "Video player configuration error" w Lavalink.
NYXIO_PO_TOKEN=
NYXIO_VISITOR_DATA=
